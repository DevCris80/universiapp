<%- include('partials/header', { view: 'crear-viaje', usuario: usuario }) %>

<section class="form-section reveal" style="align-items: flex-start;">
  <div class="form-card" style="max-width: 560px;">
    <h2 class="section-title">Publicar <em>Viaje</em></h2>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash-message flash-error"><%= error %></div>
    <% } %>
    <form action="/viaje/nuevo" method="POST" id="crear-viaje-form">
      <div class="form-group">
        <label class="form-label" for="tipo_servicio">Tipo de servicio</label>
        <select class="form-select" id="tipo_servicio" name="tipo_servicio" required>
          <option value="universidad">Hacia la Universidad 🎓</option>
          <option value="destino">Hacia mi destino 📍</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Ubicación de salida</label>
        <div id="mode-badge" class="badge badge-universidad">🎓 Salgo desde mi ubicación actual</div>
        <div class="map-picker" id="map-picker"></div>
        <input type="hidden" name="lat" id="lat" required>
        <input type="hidden" name="lng" id="lng" required>
        <small id="map-hint" class="map-hint"></small>
      </div>
      <div class="form-group">
        <label class="form-label" for="direccion">Dirección / Referencia</label>
        <input class="form-input" type="text" id="direccion" name="direccion" placeholder="Ej: Puerta principal, bloque 3" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="vehiculo">Vehículo</label>
        <select class="form-select" id="vehiculo" name="vehiculo" required>
          <option value="">Selecciona...</option>
          <option value="moto">Moto</option>
          <option value="carro">Carro</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="form-group">
          <label class="form-label" for="tarifa">Tarifa ($)</label>
          <input class="form-input" type="number" id="tarifa" name="tarifa" placeholder="5000" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="cupos">Cupos</label>
          <input class="form-input" type="number" id="cupos" name="cupos" readonly required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="hora_salida">Hora de salida</label>
        <input class="form-input" type="time" id="hora_salida" name="hora_salida" required>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary">Publicar Viaje</button>
      </div>
    </form>
  </div>
</section>

  <script>
  var UNIVERSIDAD_COORDS = [4.629, -74.065]

  document.addEventListener('DOMContentLoaded', function() {
    var picker = L.map('map-picker').setView(UNIVERSIDAD_COORDS, 14)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap' }).addTo(picker)
    var marker = null
    var uniMarker = L.marker(UNIVERSIDAD_COORDS, {
      icon: L.divIcon({
        className: 'uni-marker',
        html: '<div style="background:#4338ca;color:white;padding:4px 10px;border-radius:9999px;font:700 0.7rem/1 Inter,sans-serif;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.3);">🎓 U. Católica</div>',
        iconSize: [120, 28],
        iconAnchor: [60, 14]
      })
    }).addTo(picker)
    var currentPos = null

    if ('geolocation' in navigator) {
      navigator.geolocation.getCurrentPosition(function(pos) {
        currentPos = [pos.coords.latitude, pos.coords.longitude]
        picker.setView(currentPos, 15)
        document.getElementById('lat').value = pos.coords.latitude.toFixed(6)
        document.getElementById('lng').value = pos.coords.longitude.toFixed(6)
        marker = L.marker(currentPos, {
          icon: L.divIcon({
            className: 'pos-marker',
            html: '<div style="background:#171717;color:white;padding:4px 10px;border-radius:9999px;font:700 0.7rem/1 Inter,sans-serif;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.3);">📍 Salida</div>',
            iconSize: [80, 28],
            iconAnchor: [40, 14]
          })
        }).addTo(picker)
        reverseGeocode(pos.coords.latitude, pos.coords.longitude)
      }, function() { updateMode(document.getElementById('tipo_servicio').value) })
    } else {
      updateMode(document.getElementById('tipo_servicio').value)
    }

    L.circleMarker(UNIVERSIDAD_COORDS, {
      radius: 14,
      color: '#4338ca',
      fillColor: '#4338ca',
      fillOpacity: 0.15,
      weight: 2
    }).addTo(picker)

    picker.on('click', function(e) {
      var tipo = document.getElementById('tipo_servicio').value
      if (tipo === 'universidad') return
      placeMarker(e.latlng.lat, e.latlng.lng)
      reverseGeocode(e.latlng.lat, e.latlng.lng)
    })

    function placeMarker(lat, lng) {
      document.getElementById('lat').value = lat.toFixed(6)
      document.getElementById('lng').value = lng.toFixed(6)
      if (marker) picker.removeLayer(marker)
      marker = L.marker([lat, lng], {
        icon: L.divIcon({
          className: 'pos-marker',
          html: '<div style="background:#171717;color:white;padding:4px 10px;border-radius:9999px;font:700 0.7rem/1 Inter,sans-serif;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.3);">📍 Salida</div>',
          iconSize: [80, 28],
          iconAnchor: [40, 14]
        })
      }).addTo(picker)
    }

    function updateMode(tipo) {
      var badge = document.getElementById('mode-badge')
      var hint = document.getElementById('map-hint')
      if (tipo === 'universidad') {
        badge.className = 'badge badge-universidad'
        badge.innerHTML = '🎓 Salgo desde mi ubicación actual'
        hint.innerHTML = 'Tu ubicación actual es el punto de salida. El mapa no es interactivo en este modo.'
        if (currentPos) {
          picker.setView(currentPos, 15)
          placeMarker(currentPos[0], currentPos[1])
          reverseGeocode(currentPos[0], currentPos[1])
        }
        if (uniMarker._icon) uniMarker._icon.style.opacity = '1'
        picker.dragging.disable()
      } else {
        badge.className = 'badge badge-destino'
        badge.innerHTML = '📍 Elijo un punto de salida en el mapa'
        hint.innerHTML = 'Haz clic en el mapa para marcar tu punto de salida.'
        if (!marker && currentPos) {
          picker.setView(currentPos, 15)
          placeMarker(currentPos[0], currentPos[1])
          reverseGeocode(currentPos[0], currentPos[1])
        }
        if (uniMarker._icon) uniMarker._icon.style.opacity = '0.6'
        picker.dragging.enable()
      }
    }

    document.getElementById('tipo_servicio').addEventListener('change', function() {
      updateMode(this.value)
    })

    updateMode('universidad')

    function reverseGeocode(lat, lng) {
      var input = document.getElementById('direccion')
      input.placeholder = 'Obteniendo direcci\u00F3n...'
      fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json&accept-language=es', {
        headers: { 'User-Agent': 'UniversiApp/1.0' }
      }).then(function(r) { return r.json() }).then(function(data) {
        var a = data.address || {}
        var parts = []
        if (a.road) {
          var street = a.road
          if (a.house_number) street += ' # ' + a.house_number
          parts.push(street)
        }
        if (a.suburb) parts.push(a.suburb)
        if (a.city || a.town || a.village) parts.push(a.city || a.town || a.village)
        input.value = parts.join(', ') || data.display_name || ''
        input.placeholder = 'Direcci\u00F3n / Referencia'
      }).catch(function() {
        input.placeholder = 'Direcci\u00F3n / Referencia'
      })
    }

    var cuposInput = document.getElementById('cupos')
    document.getElementById('vehiculo').addEventListener('change', function() {
      cuposInput.value = this.value === 'moto' ? 1 : this.value === 'carro' ? 3 : ''
    })

    var now = new Date()
    document.getElementById('hora_salida').value = String(now.getHours()).padStart(2, '0') + ':' + String(now.getMinutes()).padStart(2, '0')
  })
  </script>

<%- include('partials/footer') %>
